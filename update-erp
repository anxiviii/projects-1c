&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Вызываем стандартный обработчик (важно для расширений)
	Если НЕ ЗначениеЗаполнено(Параметры.Ключ) Тогда
		// Только при создании нового документа
		ЗаполнитьРеквизитОтпустил();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРеквизитОтпустил()
	
	Если НЕ ЗначениеЗаполнено(Объект.Склад) Тогда
		Возврат;
	КонецЕсли;
	
	// Проверяем, что в шапке указана именно группа складов
	Если НЕ ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "ЭтоГруппа") Тогда
		Возврат; // Обычный склад — не трогаем
	КонецЕсли;
	
	// Берем первую строку ТЧ "Товары"
	Если Объект.Товары.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПерваяСтрока = Объект.Товары[0];
	
	Если НЕ ЗначениеЗаполнено(ПерваяСтрока.Отправитель) Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем ответственного склада (Отправитель — это склад)
	Ответственный = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПерваяСтрока.Отправитель, "Ответственный");
	
	Если ЗначениеЗаполнено(Ответственный) Тогда
		Объект.Отпустил = Ответственный;
	КонецЕсли;
	
КонецПроцедуры
